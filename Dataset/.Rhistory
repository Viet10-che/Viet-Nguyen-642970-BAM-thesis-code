parse_cafef_date <- function(x) {
x <- as.character(x)
suppressWarnings({
d1 <- lubridate::ymd(x)
d2 <- lubridate::dmy(x)
})
out <- ifelse(!is.na(d1), as.character(d1), as.character(d2))
as.Date(out)
}
parse_num_vi <- function(x) {
x <- as.character(x)
x <- stringr::str_trim(x)
x <- stringr::str_replace_all(x, "\\u00A0", "")
x <- stringr::str_replace_all(x, "\\s+", "")
x <- stringr::str_replace_all(x, "\\.", "")
x <- stringr::str_replace_all(x, ",", ".")
suppressWarnings(as.numeric(x))
}
extract_change_fields <- function(change_raw) {
change_raw <- as.character(change_raw)
close_price <- stringr::str_extract(change_raw, "^[0-9.,]+")
change_pct  <- stringr::str_match(change_raw, "\\(([-+]?[0-9.,]+)\\s*%\\)")[, 2]
tibble(
close_price = parse_num_vi(close_price),
change_pct  = parse_num_vi(change_pct)
)
}
empty_df <- tibble(
ticker = character(),
date = as.Date(character()),
change_raw = character(),
net_vol = numeric(),
net_value_bil_vnd = numeric(),
buy_vol = numeric(),
buy_value_bil_vnd = numeric(),
sell_vol = numeric(),
sell_value_bil_vnd = numeric(),
foreign_room_left = numeric(),
foreign_own_pct = numeric(),
change_pct = numeric(),
close_price = numeric()
)
# =========================================================
# 3) FETCH ONE TICKER - ONE DAY ONLY
# =========================================================
fetch_one_ticker_one_day <- function(tic, one_date) {
one_mdyy <- to_mmddyyyy(one_date)
q <- list(
Symbol = tic,
StartDate = one_mdyy,
EndDate = one_mdyy,
PageIndex = 1,
PageSize = 50
)
js <- fetch_json_loose(base_url, q)
if (is.null(js$Data) || is.null(js$Data$Data) || length(js$Data$Data) == 0) {
return(empty_df)
}
raw <- as_tibble(js$Data$Data)
out <- raw |>
mutate(ticker = tic) |>
transmute(
ticker = ticker,
date = parse_cafef_date(Ngay),
change_raw = as.character(ThayDoi),
net_vol = as.numeric(KLGDRong),
net_value_bil_vnd = as.numeric(GTDGRong) / 1e9,
buy_vol = as.numeric(KLMua),
buy_value_bil_vnd = as.numeric(GtMua) / 1e9,
sell_vol = as.numeric(KLBan),
sell_value_bil_vnd = as.numeric(GtBan) / 1e9,
foreign_room_left = as.numeric(RoomConLai),
foreign_own_pct = as.numeric(DangSoHuu)
)
extra <- extract_change_fields(out$change_raw)
out <- bind_cols(out, extra) |>
distinct(ticker, date, .keep_all = TRUE) |>
arrange(ticker, date)
out
}
# =========================================================
# 4) RUN FULL RANGE (AUTO-RESUME WITH AVAILABLE DATES)
# =========================================================
if (file.exists("finalcafef_foreignflow_AAA_YEG_2014_2026.csv")) {
existing <- readr::read_csv(
"finalcafef_foreignflow_AAA_YEG_2014_2026.csv",
show_col_types = FALSE
) |>
mutate(date = as.Date(date))
} else {
existing <- empty_df
}
available_dates <- existing |>
distinct(date) |>
pull(date) |>
as.Date() |>
sort()
results <- list()
failed  <- list()
counter <- 0
for (tic in tickers) {
done_dates_tic <- existing |>
filter(ticker == tic) |>
pull(date) |>
as.Date()
remaining_dates <- setdiff(available_dates, done_dates_tic) |>
sort()
message("Ticker ", tic, " | remaining days: ", length(remaining_dates))
for (d in remaining_dates) {
d <- as.Date(d)
message("Downloading: ", tic, " | ", as.character(d))
out <- tryCatch(
fetch_one_ticker_one_day(tic, d),
error = function(e) {
failed[[length(failed) + 1]] <<- tibble(
ticker = tic,
date = as.Date(d),
reason = as.character(e$message)
)
NULL
}
)
if (!is.null(out) && nrow(out) > 0) {
results[[length(results) + 1]] <- out
}
counter <- counter + 1
if (counter %% 200 == 0) {
temp_new <- if (length(results) > 0) bind_rows(results) else empty_df
temp <- bind_rows(existing, temp_new) |>
distinct(ticker, date, .keep_all = TRUE) |>
arrange(ticker, date)
write_csv(temp, "finalcafef_foreignflow_AAA_YEG_2014_2026.csv", na = "")
message("Autosaved...")
}
Sys.sleep(0.3)
}
}
