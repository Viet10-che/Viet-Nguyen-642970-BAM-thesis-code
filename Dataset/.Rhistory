change_raw <- as.character(change_raw)
close_price <- stringr::str_extract(change_raw, "^[0-9.,]+")
change_pct  <- stringr::str_match(change_raw, "\\(([-+]?[0-9.,]+)\\s*%\\)")[, 2]
tibble(
close_price = parse_num_vi(close_price),
