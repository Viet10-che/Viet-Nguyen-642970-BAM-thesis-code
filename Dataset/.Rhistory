# =========================================================
# 4) RUN FROM LAST SAVED DATE TO 2026-02-06
# =========================================================
if (file.exists("finalcafef_foreignflow_AAA_YEG_2014_2026.csv")) {
existing <- readr::read_csv(
"finalcafef_foreignflow_AAA_YEG_2014_2026.csv",
show_col_types = FALSE
) |>
mutate(date = as.Date(date))
} else {
existing <- empty_df
}
end_date <- as.Date("2026-02-06")
results <- list()
failed  <- list()
counter <- 0
for (tic in tickers) {
tic_existing <- existing |>
filter(ticker == tic) |>
arrange(date)
if (nrow(tic_existing) > 0) {
last_date <- max(tic_existing$date, na.rm = TRUE)
remaining_dates <- seq.Date(from = last_date + 1, to = end_date, by = "day")
} else {
remaining_dates <- seq.Date(from = as.Date("2014-01-01"), to = end_date, by = "day")
}
message("Ticker ", tic, " | last saved date: ",
ifelse(nrow(tic_existing) > 0, as.character(last_date), "NONE"))
message("Ticker ", tic, " | remaining days: ", length(remaining_dates))
if (length(remaining_dates) == 0) next
for (d in remaining_dates) {
d <- as.Date(d)
message("Downloading: ", tic, " | ", as.character(d))
out <- tryCatch(
fetch_one_ticker_one_day(tic, d),
error = function(e) {
failed[[length(failed) + 1]] <<- tibble(
ticker = tic,
date = d,
reason = as.character(e$message)
)
NULL
}
)
if (!is.null(out) && nrow(out) > 0) {
results[[length(results) + 1]] <- out
}
counter <- counter + 1
if (counter %% 200 == 0) {
temp_new <- if (length(results) > 0) bind_rows(results) else empty_df
temp <- bind_rows(existing, temp_new) |>
distinct(ticker, date, .keep_all = TRUE) |>
arrange(ticker, date)
write_csv(temp, "finalcafef_foreignflow_AAA_YEG_2014_2026.csv", na = "")
message("Autosaved...")
}
Sys.sleep(0.3)
}
}
new_part <- if (length(results) > 0) bind_rows(results) else empty_df
final_full <- bind_rows(existing, new_part) |>
distinct(ticker, date, .keep_all = TRUE) |>
arrange(ticker, date)
failed_full <- if (length(failed) > 0) bind_rows(failed) else tibble(
ticker = character(),
date = as.Date(character()),
reason = character()
)
write_csv(final_full, "finalcafef_foreignflow_AAA_YEG_2014_2026.csv", na = "")
write_csv(failed_full, "finalcafef_foreignflow_AAA_YEG_failed_2014_2026.csv", na = "")
print(final_full)
print(failed_full)
View(final_full)
