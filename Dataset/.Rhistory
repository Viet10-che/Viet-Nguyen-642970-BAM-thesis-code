# =========================================================
# 1) INPUTS
# =========================================================
tickers <- c("AAA", "YEG")
full_dates <- seq.Date(
from = as.Date("2014-01-01"),
to   = as.Date("2026-02-06"),
by   = "day"
)
base_url <- "https://cafef.vn/du-lieu/Ajax/PageNew/DataHistory/GDKhoiNgoai.ashx"
# =========================================================
# 2) HELPERS
# =========================================================
`%||%` <- function(a, b) if (!is.null(a)) a else b
to_mmddyyyy <- function(date_obj) {
format(as.Date(date_obj), "%m/%d/%Y")
}
fetch_json_loose <- function(url, query, ua = "Mozilla/5.0") {
req <- request(url) |>
req_url_query(!!!query) |>
req_headers(
"User-Agent" = ua,
"Accept" = "application/json, text/plain, */*",
"Referer" = "https://cafef.vn/"
)
res <- req_perform(req)
txt <- resp_body_string(res, encoding = "UTF-8")
if (stringr::str_detect(txt, stringr::regex("<html|<!DOCTYPE", ignore_case = TRUE))) {
stop("Got HTML instead of JSON.")
}
jsonlite::fromJSON(txt, simplifyVector = TRUE)
}
parse_cafef_date <- function(x) {
x <- as.character(x)
suppressWarnings({
d1 <- lubridate::ymd(x)
d2 <- lubridate::dmy(x)
})
out <- ifelse(!is.na(d1), as.character(d1), as.character(d2))
as.Date(out)
}
