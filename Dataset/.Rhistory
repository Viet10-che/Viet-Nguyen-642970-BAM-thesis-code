library(readxl)
library(dplyr)
library(purrr)
library(openxlsx)
# =========================
# 1. FILE PATH
# =========================
file_path <- "Thesis final 8.4.26.xlsx"
sheets <- c("Sheet stock pt 1", "Sheet stock pt 2", "Sheet stock pt 3")
# =========================
# 2. READ DATA
# =========================
list_data <- lapply(sheets, function(s) {
read_excel(file_path, sheet = s, col_names = FALSE)
})
# =========================
# 3. MERGE (GIỮ NGUYÊN HEADER)
# =========================
df_full <- bind_cols(list_data)
# =========================
# 4. REMOVE DUPLICATE COLUMNS (giữ cột đầu tiên)
# =========================
df_full <- df_full[, !duplicated(as.character(df_full[2, ]))]
# =========================
# 5. SAVE FILE
# =========================
output_file <- "data_merged_raw_format.xlsx"
write.xlsx(df_full, output_file, overwrite = TRUE)
# =========================
# DONE
# =========================
cat("✅ DONE: merged giữ nguyên format Datastream")
