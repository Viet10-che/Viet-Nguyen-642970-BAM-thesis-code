library(dplyr)
library(readr)
library(tibble)
# =========================================
# 1) Load file final hiện tại nếu cần
# =========================================
final_full <- read_csv(
"finalcafef_foreignflow_AAA_YEG_2014_2026.csv",
show_col_types = FALSE
) |>
mutate(date = as.Date(date))
# =========================================
# 2) Lấy danh sách ngày missing của YEG
#    dùng object đã có nếu đang ở Environment
# =========================================
# Nếu đã có missing_YEG trong Environment thì giữ dòng dưới:
# yeg_missing_dates <- missing_YEG$date
# Nếu chưa có, đọc từ file:
yeg_missing_dates <- read_csv(
"cafef_missing_days_YEG.csv",
show_col_types = FALSE
) |>
mutate(date = as.Date(date)) |>
pull(date)
yeg_missing_dates <- sort(unique(yeg_missing_dates))
# =========================================
# 3) Crawl lại chỉ các ngày missing của YEG
# =========================================
results_yeg_fix <- list()
failed_yeg_fix  <- list()
counter <- 0
for (d in yeg_missing_dates) {
message("Re-downloading YEG | ", as.character(d))
out <- tryCatch(
fetch_one_ticker_one_day("YEG", d),
error = function(e) {
failed_yeg_fix[[length(failed_yeg_fix) + 1]] <<- tibble(
ticker = "YEG",
date = as.Date(d),
reason = as.character(e$message)
)
NULL
}
)
if (!is.null(out) && nrow(out) > 0) {
results_yeg_fix[[length(results_yeg_fix) + 1]] <- out
}
counter <- counter + 1
if (counter %% 100 == 0) {
message("Processed ", counter, " / ", length(yeg_missing_dates))
}
Sys.sleep(0.3)
}
# =========================================
# 4) Gộp phần tải mới
# =========================================
yeg_fix <- if (length(results_yeg_fix) > 0) bind_rows(results_yeg_fix) else tibble(
ticker = character(),
date = as.Date(character()),
change_raw = character(),
net_vol = numeric(),
net_value_bil_vnd = numeric(),
buy_vol = numeric(),
buy_value_bil_vnd = numeric(),
sell_vol = numeric(),
sell_value_bil_vnd = numeric(),
foreign_room_left = numeric(),
foreign_own_pct = numeric(),
close_price = numeric(),
change_pct = numeric()
)
failed_yeg_fix_df <- if (length(failed_yeg_fix) > 0) bind_rows(failed_yeg_fix) else tibble(
ticker = character(),
date = as.Date(character()),
reason = character()
)
# =========================================
# 5) Merge vào final_full
# =========================================
final_full_updated <- bind_rows(final_full, yeg_fix) |>
distinct(ticker, date, .keep_all = TRUE) |>
arrange(ticker, date)
# =========================================
# 6) Save file cuối
# =========================================
write_csv(final_full_updated, "finalcafef_foreignflow_AAA_YEG_2014_2026_updated.csv", na = "")
write_csv(failed_yeg_fix_df, "finalcafef_foreignflow_YEG_remaining_failed.csv", na = "")
# =========================================
# 7) Quick check
# =========================================
print(final_full_updated)
print(failed_yeg_fix_df)
View(final_full_updated)
